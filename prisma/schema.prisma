generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Usuario {
  id               String         @id @default(cuid())
  nombre           String
  email            String         @unique
  password         String
  rol              Rol            @default(TECNICO)
  activo           Boolean        @default(true)
  foto             String?
  telefono         String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  cajaAsignada     Caja?          @relation("CajaUsuario")
  cobranzas        Cobranza[]
  gastos           Gasto[]
  notas            Nota[]
  ordenesCreadas   OrdenTrabajo[] @relation("CreadorOT")
  ordenesAsignadas OrdenTrabajo[] @relation("TecnicoOT")
  presupuestos     Presupuesto[]
  servicios        Servicio[]
  tareas           Tarea[]
  ventas           Venta[]
}

model Empresa {
  id        String    @id @default(cuid())
  nombre    String    @unique
  cuit      String?
  domicilio String?
  telefono  String?
  createdAt DateTime  @default(now())
  clientes  Cliente[]
}

model Cliente {
  id              String            @id @default(cuid())
  nombre          String
  dni             String?
  email           String?
  domicilio       String?
  telefono        String?
  iva             String            @default("NO incluyen IVA")
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  empresaId       String?
  cuit            String?
  codigoExcel     String?           @unique
  cheques         Cheque[]
  empresa         Empresa?          @relation(fields: [empresaId], references: [id])
  cobranzas       Cobranza[]
  cuentaCorriente CuentaCorriente[]
  ordenes         OrdenTrabajo[]
  presupuestos    Presupuesto[]
  servicios       Servicio[]
  ventas          Venta[]

  @@index([empresaId])
}

model Maquina {
  id      String         @id @default(cuid())
  nombre  String         @unique
  marcas  Marca[]
  ordenes OrdenTrabajo[]
}

model Marca {
  id        String         @id @default(cuid())
  nombre    String
  maquinaId String
  maquina   Maquina        @relation(fields: [maquinaId], references: [id])
  modelos   Modelo[]
  ordenes   OrdenTrabajo[]

  @@unique([nombre, maquinaId])
}

model Modelo {
  id      String         @id @default(cuid())
  nombre  String
  marcaId String
  marca   Marca          @relation(fields: [marcaId], references: [id])
  ordenes OrdenTrabajo[]

  @@unique([nombre, marcaId])
}

model OrdenTrabajo {
  id                   String        @id @default(cuid())
  numero               Int           @unique @default(autoincrement())
  fechaRecepcion       DateTime      @default(now())
  fechaEntrega         DateTime?
  estado               EstadoOT      @default(RECIBIDO)
  falla                String?
  observaciones        String?
  nroSerie             String?
  accesorios           String?
  whatsappEnviado      Boolean       @default(false)
  pdfUrl               String?
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
  maquinaId            String?
  marcaId              String?
  modeloId             String?
  clienteId            String
  tecnicoId            String?
  creadorId            String
  fechaEstimadaEntrega DateTime?
  revisionTecnica      String?
  firmaCliente         String?
  fotos                Foto[]
  historial            HistorialOT[]
  notas                Nota[]
  cliente              Cliente       @relation(fields: [clienteId], references: [id])
  creador              Usuario       @relation("CreadorOT", fields: [creadorId], references: [id])
  maquina              Maquina?      @relation(fields: [maquinaId], references: [id])
  marca                Marca?        @relation(fields: [marcaId], references: [id])
  modelo               Modelo?       @relation(fields: [modeloId], references: [id])
  tecnico              Usuario?      @relation("TecnicoOT", fields: [tecnicoId], references: [id])
  presupuestos         Presupuesto[]
  retiros              Retiro[]

  @@index([clienteId])
  @@index([creadorId])
  @@index([tecnicoId])
  @@index([maquinaId])
  @@index([marcaId])
  @@index([modeloId])
}

model HistorialOT {
  id             String       @id @default(cuid())
  fecha          DateTime     @default(now())
  estadoAnterior EstadoOT?
  estadoNuevo    EstadoOT
  comentario     String?
  ordenId        String
  orden          OrdenTrabajo @relation(fields: [ordenId], references: [id])

  @@index([ordenId])
}

model Foto {
  id      String       @id @default(cuid())
  url     String
  fecha   DateTime     @default(now())
  ordenId String
  orden   OrdenTrabajo @relation(fields: [ordenId], references: [id])

  @@index([ordenId])
}

model Nota {
  id            String       @id @default(cuid())
  texto         String
  fecha         DateTime     @default(now())
  ordenId       String
  usuarioId     String
  esSeguimiento Boolean      @default(false)
  orden         OrdenTrabajo @relation(fields: [ordenId], references: [id])
  usuario       Usuario      @relation(fields: [usuarioId], references: [id])

  @@index([ordenId])
  @@index([usuarioId])
}

model Retiro {
  id        String       @id @default(cuid())
  fecha     DateTime     @default(now())
  nombre    String
  dni       String?
  firma     String?
  fotoDni   String?
  realizada Boolean      @default(false)
  ordenId   String
  orden     OrdenTrabajo @relation(fields: [ordenId], references: [id])

  @@index([ordenId])
}

model Presupuesto {
  id              String            @id @default(cuid())
  numero          Int               @unique @default(autoincrement())
  fecha           DateTime          @default(now())
  estado          EstadoPresupuesto @default(BORRADOR)
  estadoCobro     EstadoCobro       @default(PENDIENTE)
  facturaNumero   String?
  observaciones   String?
  incluyeIva      Boolean           @default(true)
  formaPago       String            @default("Contado")
  validezDias     Int               @default(7)
  moneda          String            @default("ARS")
  pdfUrl          String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  clienteId       String
  ordenId         String?
  usuarioId       String
  cobranzas       Cobranza[]
  cuentaCorriente CuentaCorriente[]
  items           ItemPresupuesto[]
  cliente         Cliente           @relation(fields: [clienteId], references: [id])
  orden           OrdenTrabajo?     @relation(fields: [ordenId], references: [id])
  usuario         Usuario           @relation(fields: [usuarioId], references: [id])

  @@index([clienteId])
  @@index([usuarioId])
  @@index([ordenId])
}

model ItemPresupuesto {
  id            String      @id @default(cuid())
  cantidad      Int         @default(1)
  descripcion   String
  precio        Float
  total         Float
  presupuestoId String
  presupuesto   Presupuesto @relation(fields: [presupuestoId], references: [id], onDelete: Cascade)

  @@index([presupuestoId])
}

model Servicio {
  id          String   @id @default(cuid())
  fecha       DateTime @default(now())
  descripcion String
  ubicacion   String?
  precio      Float
  estado      String   @default("PENDIENTE")
  createdAt   DateTime @default(now())
  clienteId   String
  tecnicoId   String?
  cliente     Cliente  @relation(fields: [clienteId], references: [id])
  tecnico     Usuario? @relation(fields: [tecnicoId], references: [id])

  @@index([clienteId])
  @@index([tecnicoId])
}

model Producto {
  id          String      @id @default(cuid())
  nombre      String
  descripcion String?
  precio      Float
  stockActual Int         @default(0)
  stockMinimo Int         @default(0)
  categoria   String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  itemsVenta  ItemVenta[]
}

model Venta {
  id         String      @id @default(cuid())
  numero     Int         @unique @default(autoincrement())
  fecha      DateTime    @default(now())
  total      Float
  formaPago  String      @default("Efectivo")
  estado     String      @default("COMPLETADA")
  createdAt  DateTime    @default(now())
  clienteId  String?
  vendedorId String?
  items      ItemVenta[]
  cliente    Cliente?    @relation(fields: [clienteId], references: [id])
  vendedor   Usuario?    @relation(fields: [vendedorId], references: [id])

  @@index([clienteId])
  @@index([vendedorId])
}

model ItemVenta {
  id         String   @id @default(cuid())
  cantidad   Int
  precio     Float
  total      Float
  productoId String
  ventaId    String
  producto   Producto @relation(fields: [productoId], references: [id])
  venta      Venta    @relation(fields: [ventaId], references: [id], onDelete: Cascade)

  @@index([productoId])
  @@index([ventaId])
}

model Caja {
  id                    String              @id @default(cuid())
  nombre                String              @unique
  usuarioId             String?             @unique
  usuario               Usuario?            @relation("CajaUsuario", fields: [usuarioId], references: [id])
  cobranzas             Cobranza[]
  gastos                Gasto[]
  movimientos           MovimientoCaja[]
  transferenciasDestino TransferenciaCaja[] @relation("CajaDestino")
  transferenciasOrigen  TransferenciaCaja[] @relation("CajaOrigen")
}

model MovimientoCaja {
  id          String   @id @default(cuid())
  fecha       DateTime @default(now())
  descripcion String
  ingreso     Float    @default(0)
  egreso      Float    @default(0)
  formaPago   String   @default("Efectivo")
  cajaId      String
  cobranzaId  String?
  gastoId     String?
  chequeId    String?
  caja        Caja     @relation(fields: [cajaId], references: [id])

  @@index([cajaId])
  @@index([cobranzaId])
  @@index([gastoId])
  @@index([chequeId])
}

model Gasto {
  id          String     @id @default(cuid())
  tipo        TipoGasto  @default(GASTO_VARIOS)
  fecha       DateTime   @default(now())
  descripcion String
  importe     Float
  formaPago   String     @default("Efectivo")
  comprobante String?
  firma       String?
  pdfUrl      String?
  createdAt   DateTime   @default(now())
  empleado    String?
  desde       DateTime?
  hasta       DateTime?
  proveedorId String?
  cajaId      String
  usuarioId   String
  chequeId    String?
  caja        Caja       @relation(fields: [cajaId], references: [id])
  cheque      Cheque?    @relation(fields: [chequeId], references: [id])
  proveedor   Proveedor? @relation(fields: [proveedorId], references: [id])
  usuario     Usuario    @relation(fields: [usuarioId], references: [id])

  @@index([proveedorId])
  @@index([cajaId])
  @@index([usuarioId])
  @@index([chequeId])
}

model Cobranza {
  id              String            @id @default(cuid())
  tipo            TipoCobranza      @default(PRESUPUESTO)
  fecha           DateTime          @default(now())
  descripcion     String?
  importe         Float
  formaPago       String            @default("Efectivo")
  createdAt       DateTime          @default(now())
  clienteId       String?
  presupuestoId   String?
  cajaId          String
  usuarioId       String
  chequeId        String?
  caja            Caja              @relation(fields: [cajaId], references: [id])
  cheque          Cheque?           @relation(fields: [chequeId], references: [id])
  cliente         Cliente?          @relation(fields: [clienteId], references: [id])
  presupuesto     Presupuesto?      @relation(fields: [presupuestoId], references: [id])
  usuario         Usuario           @relation(fields: [usuarioId], references: [id])
  cuentaCorriente CuentaCorriente[]

  @@index([clienteId])
  @@index([presupuestoId])
  @@index([cajaId])
  @@index([usuarioId])
  @@index([chequeId])
}

model TransferenciaCaja {
  id               String   @id @default(cuid())
  fecha            DateTime @default(now())
  monto            Float
  descripcion      String?
  formaPagoOrigen  String   @default("Efectivo")
  formaPagoDestino String   @default("Efectivo")
  cajaOrigenId     String
  cajaDestinoId    String
  chequeId         String?
  cajaDestino      Caja     @relation("CajaDestino", fields: [cajaDestinoId], references: [id])
  cajaOrigen       Caja     @relation("CajaOrigen", fields: [cajaOrigenId], references: [id])

  @@index([cajaOrigenId])
  @@index([cajaDestinoId])
  @@index([chequeId])
}

model Cheque {
  id           String       @id @default(cuid())
  estado       EstadoCheque @default(EN_CARTERA)
  numeroCheque String?
  banco        String?
  librador     String?
  importe      Float
  fechaIngreso DateTime     @default(now())
  fechaEmision DateTime?
  fechaCobro   DateTime?
  fotoFrente   String?
  fotoDorso    String?
  endosadoA    String?
  descripcion  String?
  clienteId    String?
  cliente      Cliente?     @relation(fields: [clienteId], references: [id])
  cobranzas    Cobranza[]
  gastos       Gasto[]

  @@index([clienteId])
}

model CuentaCorriente {
  id            String                 @id @default(cuid())
  clienteId     String
  tipo          TipoMovimientoCuenta
  origen        OrigenMovimientoCuenta
  monto         Float                  @default(0)
  fecha         DateTime               @default(now())
  presupuestoId String?
  cobranzaId    String?
  cliente       Cliente                @relation(fields: [clienteId], references: [id])
  cobranza      Cobranza?              @relation(fields: [cobranzaId], references: [id])
  presupuesto   Presupuesto?           @relation(fields: [presupuestoId], references: [id])

  @@index([clienteId])
  @@index([presupuestoId])
  @@index([cobranzaId])
}

model Proveedor {
  id        String   @id @default(cuid())
  nombre    String
  empresa   String?
  cuit      String?
  email     String?
  domicilio String?
  telefono  String?
  iva       String?
  createdAt DateTime @default(now())
  rubro     String?
  gastos    Gasto[]
}

model Tarea {
  id            String         @id @default(cuid())
  descripcion   String
  estado        EstadoTarea    @default(PENDIENTE)
  prioridad     PrioridadTarea @default(MEDIA)
  fecha         DateTime       @default(now())
  vencimiento   DateTime?
  observaciones String?
  usuarioId     String
  usuario       Usuario        @relation(fields: [usuarioId], references: [id])

  @@index([usuarioId])
}

model Falla {
  id     String @id @default(cuid())
  nombre String @unique
}

model AccesorioCatalogo {
  id     String @id @default(cuid())
  nombre String @unique
}

model ColaMensajes {
  id                String   @id @default(cuid())
  tipoNotificacion  String
  destinatario      String?
  datos             String
  procesarDespuesDe DateTime
  estado            String   @default("PENDIENTE")
  reintentos        Int      @default(0)
  creadoEn          DateTime @default(now())
  actualizadoEn     DateTime @updatedAt
}

model Configuracion {
  clave String @id
  valor String
}

enum Rol {
  ADMIN
  TECNICO
  CAJA
  VENTAS
  JEFE
  ADMINISTRACION
}

enum EstadoOT {
  RECIBIDO
  PARA_REVISAR
  EN_REVISION
  REVISADO
  PARA_PRESUPUESTAR
  PRESUPUESTADO
  APROBADO
  EN_REPARACION
  REPARADO
  PARA_ENTREGAR
  ENTREGADO_REALIZADO
  ENTREGADO_SIN_REALIZAR
  RECHAZADO
}

enum EstadoPresupuesto {
  BORRADOR
  PRESUPUESTADO
  APROBADO
  RECHAZADO
}

enum EstadoCobro {
  PENDIENTE
  APROBACION_PENDIENTE
  COBRO_PENDIENTE
  COBRADO
  PARCIAL
}

enum TipoGasto {
  GASTO_VARIOS
  SUELDO
  INSUMOS
  MANTENIMIENTO
  IMPUESTOS
  LOGISTICA
  EQUIPAMIENTO
}

enum TipoCobranza {
  PRESUPUESTO
  COBRANZA_VARIA
}

enum EstadoCheque {
  DEPOSITADO
  EN_CARTERA
  ENDOSADO
  COBRADO
  RECHAZADO
  VENCIDO
}

enum TipoMovimientoCuenta {
  DEBE
  HABER
}

enum OrigenMovimientoCuenta {
  PRESUPUESTO
  COBRANZA
  MANUAL
}

enum PrioridadTarea {
  BAJA
  MEDIA
  ALTA
  URGENTE
}

enum EstadoTarea {
  PENDIENTE
  EN_PROGRESO
  COMPLETADA
}
